# Runtime env
ARBER_ENV=dev

# Database
ARBER_DB_DSN=postgresql+asyncpg://arber:arber@localhost:5433/arber
ARBER_DB_POOL_SIZE=10
ARBER_DB_MAX_OVERFLOW=20
ARBER_DB_ECHO=false

# HTTP
ARBER_HTTP_DEFAULT_TIMEOUT_S=15
ARBER_HTTP_DEFAULT_RATE_LIMIT_RPS=2
ARBER_HTTP_USER_AGENT=arber/0.1

# Scheduler (seconds)
ARBER_SCHED_REFERENCE_SYNC_INTERVAL_S=21600
ARBER_SCHED_BOOKMAKER_FIXTURES_INTERVAL_S=900
ARBER_SCHED_ODDS_FETCH_INTERVAL_S=45
ARBER_SCHED_RESOLVE_UNMATCHED_INTERVAL_S=300
ARBER_SCHED_PROMOTE_CANDIDATES_INTERVAL_S=600

# Observability
ARBER_OBS_METRICS_HOST=127.0.0.1
ARBER_OBS_METRICS_PORT=9464
ARBER_OBS_LOG_LEVEL=INFO
ARBER_OBS_LOG_FORMAT=console
